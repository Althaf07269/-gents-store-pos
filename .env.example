# Copy to .env and set values for PostgreSQL (recommended for production/client)

DB_ENGINE=postgresql
DB_NAME=gents_pos
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

SECRET_KEY=change-this-in-production
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,127.0.0.1

# Local dev without PostgreSQL: DB_ENGINE=sqlite
